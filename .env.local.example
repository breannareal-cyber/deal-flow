# ── Scraping (Apify) ────────────────────────────────────────────
# Your Apify API token. Required for real scraping.
APIFY_TOKEN=
# BizBuySell actor. Default = shahidirfan (beats Akamai, 45 rich fields).
APIFY_ACTOR_ID=XynfRyQZTeRhNeYrF
# State category pages to scrape (keyword search is broken; state filtering works).
# Colorado (bullseye) + Wyoming. We pull these and filter to water in-code.
BIZBUYSELL_STATE_URLS=https://www.bizbuysell.com/colorado-businesses-for-sale/,https://www.bizbuysell.com/wyoming-businesses-for-sale/
# How many listings to scan per state before pre-filtering (water businesses are rare)
BIZBUYSELL_RESULTS_PER_STATE=60

# ── AI scoring + research synthesis (Anthropic) ─────────────────
# Required for scoring. Without it, listings scrape but show "not yet scored".
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Web research (Tavily) ───────────────────────────────────────
# Optional. Without it, research is skipped (scoring still works).
TAVILY_API_KEY=

# ── Production database (Neon) ──────────────────────────────────
# Optional for local demo (uses .data/listings.json instead).
# Required for Vercel production (read-only filesystem there).
DATABASE_URL=

# ── Security ────────────────────────────────────────────────────
# Protects cron + manual routes in production. Leave blank for local dev.
CRON_SECRET=
